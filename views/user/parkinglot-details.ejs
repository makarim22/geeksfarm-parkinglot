<!DOCTYPE html>  
<html lang="en">  
<head>  
    <meta charset="UTF-8">  
    <meta name="viewport" content="width=device-width, initial-scale=1.0">  
    <title>Available Parking Lots</title>  
    <!-- Bootstrap CSS via CDN -->  
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">  
    <style>  
        .card-img-top {  
            height: 300px; /* Set the desired height for all images */  
            object-fit: cover; /* Ensures the aspect ratio is maintained and fills the space */  
        }  
      nav {
        display: flex;
        justify-content: center;
        padding: 10px 0;
        background-color: #007bff;
        color: #fff;
      }

      nav a {
        color: white;
        margin: 0 15px;
        text-decoration: none;
        font-weight: bold;
      }

      nav a:hover {
        text-decoration: underline;
      }
    </style>  
</head>  
<nav class="navbar navbar-expand-lg navbar-light bg-light">  
    <div class="container">  
        <a href="/user/dashboard" class="navbar-brand">  
            <img src="/images/parkuy2.png" class="logo" alt="Logo" style="height: 120px;"> <!-- Set a height -->  
            <!-- `40px` is an example value; adjust as necessary -->  
        </a>  
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">  
            <span class="navbar-toggler-icon"></span>  
        </button>  
        <div class="collapse navbar-collapse" id="navbarNav">  
            <ul class="navbar-nav"> <!-- Align items to the left -->  
                <li class="nav-item"><a class="nav-link" href="/user/dashboard">Dashboard</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/profile">Profile</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/ticket">Ticket</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/parkinglot-details">Explore</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/about">About</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/contact">Contact</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/faq">FAQ</a></li>  
            </ul>  
        </div>  
    </div>  
</nav>
<body>  
  
    <div class="container mt-5">  
        <h1 class="text-center" >Available Parking Lots</h1>  
        <div class="row">  
            <% parkingLots.forEach(lot => { %>  
                <div class="col-md-4 mb-4">  
                    <div class="card">  
                        <img src="<%= lot.photo %>" class="card-img-top" alt="<%= lot.name %>">  
                        <div class="card-body">  
                            <h5 class="card-title"><%= lot.name %></h5>  
                            <p class="card-text"><strong>Address:</strong> <%= lot.address %></p>  
                            <p><strong>Opening Time:</strong> <%= lot.openingTime %> </p>  
                            <p><strong>Closing Time:</strong> <%= lot.closingTime %> </p>
                            <p><strong>Tarif motor (per jam):</strong> <%= lot.motorcycle_tariff %> </p>  
                            <p><strong>Tarif mobil (per jam):</strong> <%= lot.car_tariff %> </p>    
                            <p><strong>Rating:</strong> <%= lot.rating %> ⭐</p>  
 
                            <hr>  
                            <h6>Reviews:</h6>  
                            <ul class="list-group">  
                                <% lot.reviews.forEach(review => { %>  
                                    <li class="list-group-item"><%= review %></li>  
                                <% }); %>  
                            </ul>  
                        </div>  
                    </div>  
                </div>  
            <% }); %>  
        </div>  
    </div>  
   
</div>  


    <!-- Bootstrap JS via CDN (with dependencies Popper.js and jQuery) -->  
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>  
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"></script>  
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>  
</body>  
</html>