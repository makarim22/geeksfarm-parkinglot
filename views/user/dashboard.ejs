<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Parking Dashboard</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    
    <style>
   

      body {
        font-family: Arial, sans-serif;
        background-color: #f4f4f4;
        color: #333;
        line-height: 1.6;
      }

      .container {
        max-width: 1200px; /* Max width for larger screens */
        margin: 0 auto; /* Center the container */
        padding: 20px; /* Padding around the content */
        text-align: center; /* Center all text in the container */
      }

      h1,
      h2 {
        text-align: center;
        margin-bottom: 20px;
        color: #4a4a4a;
      }

      nav {
        display: flex;
        justify-content: center;
        padding: 10px 0;
        background-color: #007bff;
        color: #fff;
      }

      nav a {
        color: white;
        margin: 0 15px;
        text-decoration: none;
        font-weight: bold;
      }

      nav a:hover {
        text-decoration: underline;
      }

      #map {
        height: 500px; /* Increased height for better visibility */
        width: 100%;
        margin: 20px 0;
        border: 2px solid #007bff;
        border-radius: 8px;
      }

      #locationForm {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 20px;
      }
      

      .input-group {
        display: flex;
        width: 100%;
        max-width: 400px;
      }

      #location {
        padding: 10px;
        border: 1px solid #007bff;
        border-radius: 5px;
        margin-right: 10px;
        width: calc(100% - 150px);
      }

      button {
        padding: 10px 15px;
        background-color: #007bff;
        color: white;
        border: 1px solid #007bff;
        border-radius: 5px;
        cursor: pointer;
        transition: background-color 0.3s;
      }

      button:hover {
        background-color: #0056b3;
      }

      ul {
        list-style-type: none;
        padding: 0;
        margin: 20px 0;
        max-width: 600px;
        margin: 0 auto;
      }

      li {
        background: white;
        padding: 15px;
        margin: 10px 0;
        border-radius: 8px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
      }

      strong {
        display: block;
        margin-bottom: 5px;
        color: #007bff;
      }

      input[type="datetime-local"],
      #location {
        width: calc(100% - 22px);
        padding: 10px;
        margin-top: 5px;
        border: 1px solid #007bff;
        border-radius: 5px;
      }

      @media (max-width: 600px) {
        #location {
          width: 90%;
        }

        input[type="datetime-local"] {
          width: calc(100% - 22px);
        }
      }

      /* Typing effect styles */
      .typing {
        font-size: 25px;
        font-weight: bold;
        white-space: nowrap; /* Prevent line breaks */
        overflow: hidden; /* Hide the overflow for the typing effect */
        border-right: 0.15em solid; /* Create a cursor effect */
        animation: blink-caret 0.8s step-end infinite; /* Blinking cursor effect */
        display: inline-block;
        text-align: center; /* Center the typing text */
      }

      @keyframes blink-caret {
        from,
        to {
          border-color: transparent;
        }
        50% {
          border-color: rgba(7, 119, 247, 0.941);
        }
      }

      footer {
        margin-top: 20px;
        text-align: center;
      }
      #result .alert {
        width: 300px; /* Set width for the square container */
        height: 300px; /* Set fixed height to create a square shape */
        display: flex;
        flex-direction: column; /* Align items in column */
        justify-content: center; /* Center content vertically */
        align-items: center; /* Center content horizontally */
        text-align: center; /* Center text */
        border: 2px solid #007bff; /* Define border style */
        border-radius: 8px; /* Style edges with rounded corners */
        background-color: #f8f9fa; /* Light background color for contrast */
        margin: 0 auto; /* Center container in its parent */
      }
      .custom-alert {  
        position: fixed;  
        top: 20px;  
        right: 20px;  
        z-index: 1050;  
        min-width: 300px;  
        max-width: 400px;  
        padding: 15px;  
        border-radius: 8px;  
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);  
        display: flex;  
        align-items: center;  
        transform: translateX(120%);  
        transition: all 0.4s ease-in-out;  
        opacity: 0;  
    }  

    .custom-alert.show {  
        transform: translateX(0);  
        opacity: 1;  
    }  

    .custom-alert-icon {  
        margin-right: 15px;  
        font-size: 24px;  
    }  

    .custom-alert-content {  
        flex-grow: 1;  
    }  

    .custom-alert-close {  
        background: none;  
        border: none;  
        font-size: 20px;  
        cursor: pointer;  
        color: rgba(0,0,0,0.5);  
        transition: color 0.3s ease;  
    }  

    .custom-alert-close:hover {  
        color: rgba(0,0,0,0.8);  
    }  

    /* Error Alert */  
    .custom-alert-error {  
        background-color: #fff2f2;  
        border-left: 5px solid #ff4d4f;  
        color: #ff4d4f;  
    }  

    .custom-alert-error .custom-alert-icon {  
        color: #ff4d4f;  
    }  

    /* Success Alert */  
    .custom-alert-success {  
        background-color: #f6ffed;  
        border-left: 5px solid #52c41a;  
        color: #52c41a;  
    }  

    .custom-alert-success .custom-alert-icon {  
        color: #52c41a;  
    }  

    /* Warning Alert */  
    .custom-alert-warning {  
        background-color: #fffbe6;  
        border-left: 5px solid #faad14;  
        color: #faad14;  
    }  

    .custom-alert-warning .custom-alert-icon {  
        color: #faad14;  
    }  
    </style>
  </head>

  <nav class="navbar navbar-expand-lg navbar-light bg-light">  
    <div class="container">  
        <a href="/user/dashboard" class="navbar-brand">  
            <img src="/images/parkuy2.png" class="logo" alt="Logo" style="height: 120px;"> <!-- Set a height -->  
            <!-- `40px` is an example value; adjust as necessary -->  
        </a>  
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">  
            <span class="navbar-toggler-icon"></span>  
        </button>  
        <div class="collapse navbar-collapse" id="navbarNav">  
            <ul class="navbar-nav"> <!-- Align items to the left -->  
                <li class="nav-item"><a class="nav-link" href="/user/dashboard">Dashboard</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/profile">Profile</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/ticket">Ticket</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/parkinglot-details">Explore</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/about">About</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/contact">Contact</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/faq">FAQ</a></li>  
            </ul>  
        </div>  
    </div>  
</nav>
  <body>
    <div class="container">
      <h1>Find Parking Lot Nearby</h1>
      <h1 class="typing" id="typing-text"></h1>

      <form id="locationForm" class="mb-3"> <!-- Added margin for spacing -->  
        <div class="input-group">  
            <input  
                type="text"  
                id="location"  
                class="form-control"
                required  
                placeholder="e.g., Cibaduyut, Bandung"  
            />  
            <button type="submit" class="btn btn-primary">Find</button>  
        </div>  
    </form>

      <div id="map"></div>

      <div id="result" class="mt-4" style="display: none">
        <div
          class="alert alert-info text-center"
          role="alert"
          style="border-radius: 8px; width: 300px; margin: 0 auto"
        >
          <p id="resultText"></p>
          <!-- Add placeholder for distance text -->
          <a id="directionsBtn" href="#" class="btn btn-primary" target="_blank"
            >Get Directions</a
          >
        </div>
      </div>
    </div>
    <% if (errorMessage) { %>  
      <div class="alert alert-danger alert-dismissible fade show" role="alert">  
        <%= errorMessage %>  
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">  
          <span aria-hidden="true">&times;</span>  
        </button>  
      </div>  
    <% } %>  
    
    <% if (successMessage) { %>  
      <div class="alert alert-success alert-dismissible fade show" role="alert">  
        <%= successMessage %>  
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">  
          <span aria-hidden="true">&times;</span>  
        </button>  
      </div>  
    <% } %>
    <ul class="list-unstyled">  
      <% parkingLots.forEach((lot) => { %>  
      <li class="mb-2 text-center">  <!-- Added text-center class here -->  
          <strong><%= lot.name %></strong><br>  
          <span><%= lot.motorcycleAvailableSpot %> motorcycle spots available</span> |  
          <span><%= lot.carAvailableSpot %> car spots available</span>   
          <br>  
          <span>Motorcycle tariff (per hour): Rp <%= lot.motorcycle_tariff %></span> |  
          <span>Car tariff (per hour): Rp <%= lot.car_tariff %></span>  
          <br>  
          <div class="mt-2"> <!-- Margin-top for spacing -->  
              <button type="button" class="btn btn-primary book-button"   
                      data-toggle="modal" data-target="#bookingModal"  
                      data-lot-id="<%= lot.id %>"  
                      data-user-id="<%= userId %>"  
                      data-lot-name="<%= lot.name %>">  
                  Book  
              </button>  
          </div>  
      </li>  
      <% }); %>  
  </ul>
</div>  

<!-- Booking Modal -->  
<div class="modal fade" id="bookingModal" tabindex="-1" role="dialog" aria-labelledby="bookingModalLabel" aria-hidden="true">  
  <div class="modal-dialog" role="document">  
      <div class="modal-content">  
          <div class="modal-header">  
              <h5 class="modal-title" id="bookingModalLabel">Book Your Parking Spot</h5>  
              <button type="button" class="close" data-dismiss="modal" aria-label="Close">  
                  <span aria-hidden="true">&times;</span>  
              </button>  
          </div>  
          <div class="modal-body">  
              <form action="/book" method="POST" id="bookingForm">  
                  <input type="hidden" name="parkingLotId" id="parkingLotId" />  
                  <input type="hidden" name="userId"  id="userId" />  

                  <div class="form-group">  
                      <label for="vehicleType">Vehicle Type:</label>  
                      <select name="vehicleType" id="vehicleType" class="form-control" required>  
                          <option value="motorcycle">Motorcycle</option>  
                          <option value="car">Car</option>  
                      </select>  
                  </div>  

                  <div class="form-group">  
                      <label for="startTime">Start Time:</label>  
                      <input type="datetime-local" id="startTime" name="startTime" class="form-control" required />  
                  </div>  

                  <div class="form-group">  
                      <label for="endTime">End Time:</label>  
                      <input type="datetime-local" id="endTime" name="endTime" class="form-control" required />  
                  </div>  

                  <button type="submit" class="btn btn-primary">Book</button>  
              </form>  
            
          </div>  
      </div>  
  </div>  
</div>  
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>  
<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>  
<!-- Make sure the version of Bootstrap JS corresponds with the Bootstrap CSS version -->  
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>  
<script>   
document.querySelectorAll('.book-button').forEach(button => {  
    button.addEventListener('click', function() {  
        const lotId = this.getAttribute('data-lot-id');  
        const userId = this.getAttribute('data-user-id');  
        const lotName = this.getAttribute('data-lot-name');  

        // Create a variable to hold the hidden inputs  
        const hiddenInputs = {  
            parkingLotId: document.getElementById('parkingLotId'),  
            userId: document.getElementById('userId')  
        };  

        // Populate the hidden inputs using the variable  
        hiddenInputs.parkingLotId.value = lotId;  
        hiddenInputs.userId.value = userId;  

        document.getElementById('bookingModalLabel').innerText = `Book ${lotName}`;  
    });  
});

</script>  

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
              function getDistanceBetweenPoints(lat1, lon1, lat2, lon2) {
                  const R = 6371; // Earth radius in kilometers
                  const dLat = degreesToRadians(lat2 - lat1);
                  const dLon = degreesToRadians(lon2 - lon1);
                  const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                            Math.cos(degreesToRadians(lat1)) * Math.cos(degreesToRadians(lat2)) *
                            Math.sin(dLon / 2) * Math.sin(dLon / 2);
                  const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
                  return R * c; // Distance in kilometers
              }

              function degreesToRadians(degrees) {
                  return degrees * (Math.PI / 180);
              }

              const parkingLots = [
                  <% parkingLots.forEach(lot => { %>
                      { id: <%= lot.id %>, name: '<%= lot.name %>', latitude: <%= lot.latitude %>, longitude: <%= lot.longitude %> },
                  <% }); %>
              ];

              const map = L.map('map').setView([-6.903889, 107.576389], 12);
              L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                  maxZoom: 19,
                  attribution: '© OpenStreetMap contributors'
              }).addTo(map);

              parkingLots.forEach(lot => {
                  L.marker([lot.latitude, lot.longitude])
                      .addTo(map)
                      .bindPopup(lot.name);
              });

              document.getElementById('locationForm').addEventListener('submit', function(e) {
                  e.preventDefault();
                  const location = document.getElementById('location').value;
                  findNearestParking(location);
              });

              async function findNearestParking(location) {
          const apiKey = '00e706971665492fb55b82a71c48c6e7';
          const geocodeUrl = `https://api.opencagedata.com/geocode/v1/json?q=${encodeURIComponent(location)}&key=${apiKey}`;

          try {
              const response = await fetch(geocodeUrl);
              const data = await response.json();

              if (data.results.length > 0) {
                  const userLocation = data.results[0].geometry;
                  const userLat = userLocation.lat;
                  const userLng = userLocation.lng;

                  const nearestLot = findNearestParkingLot(userLat, userLng);
                  if (nearestLot) {
                      const distance = getDistanceBetweenPoints(userLat, userLng, nearestLot.latitude, nearestLot.longitude);

                      // Display the result using improved HTML structure
                      document.getElementById('resultText').innerHTML = `
                          The nearest parking lot is <strong>${nearestLot.name}</strong>, which is
                          <strong>${distance.toFixed(2)}</strong> km away.
                      `;
                      // Update the directions link
                      document.getElementById('directionsBtn').href = `https://www.google.com/maps/dir/?api=1&destination=${nearestLot.latitude},${nearestLot.longitude}`;

                      // Show the result container
                      document.getElementById('result').style.display = 'block';
                      map.setView([nearestLot.latitude, nearestLot.longitude], 15);
                      L.marker([nearestLot.latitude, nearestLot.longitude]).addTo(map).bindPopup(`Nearest Lot: ${nearestLot.name}`).openPopup();
                  } else {
                      document.getElementById('resultText').innerHTML = 'No parking lots found nearby.';
                      document.getElementById('result').style.display = 'block';  // Show the result as well
                  }
              } else {
                  document.getElementById('resultText').innerHTML = 'Location not found. Please try again.';
                  document.getElementById('result').style.display = 'block';  // Show the result as well
              }
          } catch (error) {
              console.error('Error fetching the location:', error);
              document.getElementById('resultText').innerHTML = 'An error occurred while finding your location.';
              document.getElementById('result').style.display = 'block';  // Show the result as well
          }
      }

              function findNearestParkingLot(userLat, userLng) {
                  let nearestLot = null;
                  let minDistance = Infinity;

                  parkingLots.forEach(lot => {
                      const distance = getDistanceBetweenPoints(userLat, userLng, lot.latitude, lot.longitude);
                      if (distance < minDistance) {
                          minDistance = distance;
                          nearestLot = lot;
                      }
                  });

                  return nearestLot;
              }

              // Typing effect script

      // Typing effect script
      const typingTextElement = document.getElementById('typing-text');

      // Function to start typing effect with the user's name
      function startTypingEffect(name) {
          const typingText = `Hello ${name}! where are you going?`;
          let i = 0;

          function type() {
              if (i < typingText.length) {
                  typingTextElement.innerHTML += typingText.charAt(i);
                  i++;
                  setTimeout(type, 150); // Adjust typing speed here
              } else {
                  setTimeout(() => {
                      typingTextElement.innerHTML = '';
                      i = 0;
                      type(); // Restart typing effect
                  }, 2000); // Delay before restarting the effect
              }
          }

          type();
      }


      startTypingEffect('<%= name %>'); // Insert the username dynamically
    </script>
  <script>
    $(document).ready(function() {  
    // Check for error messages in URL  
    const urlParams = new URLSearchParams(window.location.search);  
    const errorMessage = urlParams.get('error');  

    // If there's an error message, display it in the modal  
    if (errorMessage) {  
        $('#error-message').text(errorMessage).show(); // Show the error message  
        $('#bookingModal').modal('show'); // Show the modal when there's an error  
    }  

    // Handle the modal open event  
    $('#bookingModal').on('show.bs.modal', function (event) {  
        // Clear previous error messages  
        $('#error-message').hide().text('');  
    });  
});
  </script>
   
  </body>
</html>

<%- include ('../layouts/footer') %>
