<!DOCTYPE html>  
<html lang="en">  
<head>  
    <meta charset="UTF-8">  
    <meta name="viewport" content="width=device-width, initial-scale=1.0">  
    <title>User Profile</title>  
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>  
        body {  
            background-color: #f8f9fa; /* Light background color */  
        }  
        .card {  
            margin-bottom: 20px; /* Space between cards */  
            border-radius: 15px; /* Rounded corners */  
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1); /* Subtle shadow */  
        }  
        .profile-header {  
            background-color: #ffffff; /* Branding color */  
            color: rgb(5, 124, 243);  
            border-radius: 15px 15px 0 0; /* Rounded top corners */  
            padding: 20px;  
            text-align: center;  
            position: relative; /* Allows absolute positioning of child elements */  
        }  
        .profile-header h1 {  
            margin: 0;  
            font-size: 2.5rem;  
        }  
        .profile-header p {  
            font-size: 1.2rem;  
            margin-top: 10px;  
        }  
        .profile-picture {  
            position: absolute; /* Position the profile picture */  
            top: 7px; /* Adjust to position at the top */  
            right: 20px; /* Adjust to position at the right */  
            width: 80px; /* Set a fixed width for proper display */  
            height: 80px; /* Set a fixed height for proper display */  
            border-radius: 50%; /* Makes the image round */  
            object-fit: cover; /* Ensures the image covers the entire area */  
            border: 2px solid white; /* Optional: Add a border */  
        }  
        .btn-custom {  
            background-color: #007bff; /* Bootstrap primary color */  
            border: none;  
            border-radius: 5px;  
            padding: 10px 20px;  
            font-size: 16px;  
            width: 150px; /* Same width for buttons */  
            transition: background-color 0.3s, transform 0.2s;  
            color: white; /* Ensure text is readable */  
        }  
        .btn-custom:hover {  
            background-color: #0056b3; /* Darker blue on hover */  
            transform: scale(1.05); /* Slightly grow on hover */  
        }  
        .total-info {  
            margin-top: 15px;  
            font-weight: bold;  
        }  
        .table {  
            border-radius: 10px; /* Rounded corners for the table */  
            overflow: hidden; /* Clip corners to achieve rounded corners */  
        }  
        thead th {  
            background-color: #007bff; /* Branding color for table header */  
            color: white; /* White text for contrast */  
        }  
        tfoot th {  
            background-color: #f1f1f1; /* Light grey for footer */  
        }  
        .badge {  
            display: inline-block;  
            background-color: #007bff;  
            color: white;  
            padding: 5px 10px;  
            border-radius: 20px;  
            font-size: 14px;  
            margin: 5px;  
            transition: transform 0.3s;  
        }  
        .badge:hover {  
            transform: scale(1.05);  
        }  
        .badge-icon {  
            width: 30px; /* Set width */  
            height: auto; /* Maintain aspect ratio */  
            margin-left: 5px; /* Space between badge text and image */  
        }
        .badge img {  
            width: 20px; /* Adjust icon size */  
            height: 20px; /* Adjust icon size */  
            margin-right: 5px; /* Space between icon and text */  
        }  
        nav {
        display: flex;
        justify-content: center;
        padding: 10px 0;
        background-color: #b8c0c9;
        color: #fff;
      }

      nav a {
        color: white;
        margin: 0 15px;
        text-decoration: none;
        font-weight: bold;
      }

      nav a:hover {
        text-decoration: underline;
      }
    </style>  
</head>  
<nav class="navbar navbar-expand-lg navbar-light bg-light">  
    <div class="container">  
        <a href="/user/dashboard" class="navbar-brand">  
            <img src="/images/parkuy2.png" class="logo" alt="Logo" style="height: 120px;"> <!-- Set a height -->  
            <!-- `40px` is an example value; adjust as necessary -->  
        </a>  
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">  
            <span class="navbar-toggler-icon"></span>  
        </button>  
        <div class="collapse navbar-collapse" id="navbarNav">  
            <ul class="navbar-nav"> <!-- Align items to the left -->  
                <li class="nav-item"><a class="nav-link" href="/user/dashboard">Dashboard</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/profile">Profile</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/ticket">Ticket</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/parkinglot-details">Explore</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/about">About</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/contact">Contact</a></li>  
                <li class="nav-item"><a class="nav-link" href="/user/faq">FAQ</a></li>  
            </ul>  
        </div>  
    </div>  
</nav>
<body>  
    <div class="container my-5 mb-5">  
        <div class="profile-header">    
            <h1>Hola, <%= user.username %>!</h1>  
            <!-- Placeholder for the profile picture -->  
            <img id="profilePicture" src="" alt="Profile Picture" class="profile-picture" style="display: none;">  
        </div>  
        <br>
        <br>
        <!-- Profile Information Card -->  
        <div class="card">  
            <div class="card-body">  
                <h4 class="card-title">Account Information</h4>  
                <p><strong>Username:</strong> <%= user.username %></p>  
                <p><strong>Email:</strong> <%= user.email %></p>  
                <p><strong>Balance:</strong> Rp<%= user.coins %></p>  
                
                <!-- Awards & Badges Section -->  
                <h4>Badges:</h4>  
                <div class="d-flex flex-wrap align-items-center">  
                        <% if (bookingCount >= 50) { %>  
                            <img src="/images/elite-icon.png" alt="Elite Customer Badge" class="badge-icon">  
                            <span class="badge me-2">Elite Customer</span>  
                        <% } else if (bookingCount >= 25) { %>  
                            <img src="/images/legendary-icon.png" alt="Legendary Customer Badge" class="badge-icon">   
                            <span class="badge me-2">Legendary Customer</span>   
                        <% } else if (bookingCount >= 10) { %>  
                            <img src="/images/loyal-icon.png" alt="Loyal Customer Badge" class="badge-icon">   
                            <span class="badge me-2">Loyal Customer</span>   
                        <% } else if (bookingCount >= 5) { %>  
                            <img src="/images/frequent-icon.png" alt="Frequent Customer Badge" class="badge-icon">  
                            <span class="badge me-2">Frequent Customer</span>  
                        <% } else if (bookingCount >= 1) { %>  
                            <img src="/images/newbie-icon.png" alt="Newbie Badge" class="badge-icon">  
                            <span class="badge me-2">Newbie</span>  
                        <% } %>  
                    </div>

                <!-- Profile Picture Upload Section -->  
                <h4>Upload Your Profile Picture:</h4>  
                <form id="uploadForm">  
                    <div class="mb-3">  
                        <input type="file" class="form-control" id="imageInput" accept=".jpg, .jpeg" required>  
                    </div>  
                    <button type="button" class="btn btn-primary" onclick="showProfilePicture()">Upload</button>  
                </form>  
            </div>  
        </div>  

        <!-- Recent Bookings Table -->  
        <div class="card">  
            <div class="card-body">  
                <h5 class="card-title">Recent Bookings</h5>  

                <!-- Filtering Section -->  
                <div class="mb-3">  
                    <label for="parkingLotFilter" class="form-label">Filter by Parking Lot:</label>  
                    <select id="parkingLotFilter" class="form-select">  
                        <option value="">All</option>  
                        <% const parkingLots = new Set();   
                           recentBookings.forEach(booking => parkingLots.add(booking.parkinglotname));  
                           parkingLots.forEach(lot => { %>  
                        <option value="<%= lot %>"><%= lot %></option>  
                        <% }); %>  
                    </select>  
                </div>  

                <table class="table table-striped table-bordered" id="bookingTable">  
                    <thead>  
                        <tr>  
                            <th scope="col">#</th>  
                            <th scope="col">Parking Lot Name</th>  
                            <th scope="col">Location</th>  
                            <th scope="col">Duration (hours)</th>  
                            <th scope="col">Amount Paid (Rp)</th>  
                            <th scope="col">Booking Date</th>  
                        </tr>  
                    </thead>  
                    <tbody>  
                        <% let totalAmountPaid = 0;  
                           let totalDuration = 0; %>  
                        <% if (recentBookings && recentBookings.length) { %>  
                            <% recentBookings.forEach((booking, index) => { %>  
                                <tr class="booking-row" data-parking-lot="<%= booking.parkinglotname %>">  
                                    <th scope="row"><%= index + 1 %></th>  
                                    <td><%= booking.parkinglotname %></td>  
                                    <td><%= booking.parkinglotlocation %></td>  
                                    <td><%= booking.duration %></td>  
                                    <td>Rp<%= booking.totalCost ? booking.totalCost.toFixed(2) : '0.00' %></td>  
                                    <td><%= new Date(booking.startTime).toLocaleDateString() %></td>  
                                </tr>  
                                <% totalAmountPaid += booking.totalCost || 0;  
                                   totalDuration += booking.duration;  
                                }); %>  
                        <% } else { %>  
                            <tr>  
                                <td colspan="6" class="text-center">No recent bookings found.</td>  
                            </tr>  
                        <% } %>  
                    </tbody>  
                    <tfoot>  
                        <tr class="font-weight-bold">  
                            <th colspan="4" class="text-end">Total Amount Paid</th>  
                            <th>Rp<%= totalAmountPaid.toFixed(2) %></th>  
                            <th></th>  
                        </tr>  
                        <tr class="font-weight-bold">  
                            <th colspan="4" class="text-end">Total Duration</th>  
                            <th><%= totalDuration %> hours</th>  
                            <th></th>  
                        </tr>  
                    </tfoot>  
                </table>  
            </div>  
        </div>  

            <form action="/logout" method="POST" style="display:inline;">  
                <button type="submit" class="btn btn-custom">Logout</button>  
            </form>  
        </div>  

        <script src="https://code.jquery.com/jquery-3.6.0.slim.min.js"></script>  
        <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script>  
        <script src="https://stackpath.bootstrapcdn.com/bootstrap/5.3.0/js/bootstrap.min.js"></script>  

        <script>   
    function showProfilePicture() {  
        const fileInput = document.getElementById('imageInput');  
        const profilePicture = document.getElementById('profilePicture');  

        // Check if a file is selected  
        if (fileInput.files && fileInput.files[0]) {  
            const reader = new FileReader();  
            
            reader.onload = function(e) {  
                profilePicture.src = e.target.result; // Set the src to the uploaded image  
                profilePicture.style.display = 'block'; // Show the image  

                // Save the image data to local storage  
                localStorage.setItem('profilePicture', e.target.result);  
            }  
            reader.readAsDataURL(fileInput.files[0]); // Read the uploaded file  
        }  
    }  

    // On page load, check if there is a profile picture in local storage  
    window.onload = function() {  
        const savedImage = localStorage.getItem('profilePicture');  
        if (savedImage) {  
            const profilePicture = document.getElementById('profilePicture');  
            profilePicture.src = savedImage; // Set the src to the saved image  
            profilePicture.style.display = 'block'; // Show the image  
        }  
    }  

    // Filter functionality for the parking lot name   
    $(document).ready(function() {  
        $('#parkingLotFilter').on('change', function() {  
            var filterValue = $(this).val();  
            $('#bookingTable tbody tr.booking-row').each(function() {  
                if (filterValue === "" || $(this).data('parking-lot') === filterValue) {  
                    $(this).show();  
                } else {  
                    $(this).hide();  
                }  
            });  
        });  
    });  
</script>
    </div>  
</body>  
</html>