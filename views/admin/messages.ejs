<!DOCTYPE html>  
<html lang="en">  
<head>  
    <meta charset="UTF-8">  
    <meta name="viewport" content="width=device-width, initial-scale=1.0">  
    <title>User Messages - Admin</title>  
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">  
    <style>  
        .logo {  
            width: 250px; /* Set the desired width for the logo */  
            height: auto; /* Maintain aspect ratio */  
            margin-bottom: 10px; /* Space between logo and title */  
        }  
        .header-container {  
            display: flex;  
            align-items: center; /* Align items in the center vertically */  
            justify-content: space-between; /* Space between logo and title */  
        }  
        .admin-title {  
            text-align: center; /* Center align the title */  
            width: 100%; /* Ensure title takes the full width available */  
        }  
    </style>  
</head>  
<body class="bg-gray-100">  
    <div class="container mx-auto p-6">  
        <header class="header-container mb-6">  
            <img src="../images/parkuy2.png" alt="Parking Logo" class="logo" />  
            <h1 class="admin-title text-4xl font-bold text-gray-800 mt-2">User Contact Messages</h1>  
        </header>  
        
        <nav class="flex justify-start space-x-4 mb-6">  
            <a href="/admin/dashboard" class="text-blue-600 hover:underline">Dashboard</a>  
            <a href="/admin/manage-users" class="text-blue-600 hover:underline">Top Up Coins</a>  
            <a href="/admin/messages" class="text-blue-600 hover:underline">User Messages</a>  
            <a href="/admin/monitor-parking" class="text-blue-600 hover:underline">Monitor Parking</a>  
            <form action="/logout" method="POST" style="display:inline;">  
                <button type="submit" class="text-blue-600 hover:underline focus:outline-none">Logout</button>  
            </form>  
        </nav>  

        <section class="mt-8">  
            <table class="min-w-full bg-white border border-gray-300 shadow-md rounded-lg overflow-hidden">  
                <thead class="bg-gray-200">  
                    <tr>  
                        <th class="border-b-2 border-gray-300 px-4 py-3 text-left text-gray-700">ID</th>  
                        <th class="border-b-2 border-gray-300 px-4 py-3 text-left text-gray-700">Email</th>  
                        <th class="border-b-2 border-gray-300 px-4 py-3 text-left text-gray-700">Message</th>  
                        <th class="border-b-2 border-gray-300 px-4 py-3 text-left text-gray-700">Submitted On</th>  
                        <th class="border-b-2 border-gray-300 px-4 py-3 text-left text-gray-700">Submitted By</th>  
                    </tr>  
                </thead>  
                <tbody class="text-gray-600">  
                    <% if (messages.length) { %>  
                        <% messages.forEach(message => { %>  
                            <tr class="hover:bg-gray-100 transition-colors duration-200">  
                                <td class="border-b border-gray-300 px-4 py-3"><%= message.id %></td>  
                                <td class="border-b border-gray-300 px-4 py-3"><%= message.email %></td>  
                                <td class="border-b border-gray-300 px-4 py-3"><%= message.message %></td>  
                                <td class="border-b border-gray-300 px-4 py-3"><%= message.created_at %></td>  
                                <td class="border-b border-gray-300 px-4 py-3"><%= message.username %></td>  
                            </tr>  
                        <% }); %>  
                    <% } else { %>  
                        <tr>  
                            <td colspan="5" class="text-center border-b border-gray-300 px-4 py-3">No messages found.</td>  
                        </tr>  
                    <% } %>  
                </tbody>  
            </table>  
        </section>  
    </div>  
</body>  
</html>